# ── Broker backend ───────────────────────────────
# "metaapi" = cloud (เสียเงิน), "mt5" = MetaTrader5 terminal บน Windows (ฟรี)
BROKER_BACKEND=mt5

# MetaApi (ใช้ตอน BROKER_BACKEND=metaapi)
METAAPI_TOKEN=
ACCOUNT_ID=

# MT5 direct (ใช้ตอน BROKER_BACKEND=mt5, Windows เท่านั้น)
# เว้นว่างทั้งหมด = attach เข้า MT5 terminal ที่เปิด+login ค้างไว้
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_TERMINAL_PATH=

# ชื่อ symbol ตาม broker (Exness mini = XAUUSDm, บางที่ = GOLD)
SYMBOL=XAUUSD

OBSIDIAN_VAULT_PATH=C:/ObsidianVault/Trading
DB_PATH=trades.db

# AI provider: "anthropic" (Claude API) หรือ "ollama" (local model)
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# ใช้ตอน AI_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
# เว้นว่าง = default ตาม provider (claude-opus-4-8 หรือ qwen2.5:7b)
AI_MODEL=
