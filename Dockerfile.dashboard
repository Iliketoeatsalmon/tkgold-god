# Build stage
FROM node:20-alpine AS builder

WORKDIR /app
COPY dashboard/package.json ./
RUN npm install

COPY dashboard/ ./
# ปล่อย VITE_API_URL ว่าง → frontend ใช้ relative /api ผ่าน nginx proxy
# (ถ้า bake localhost:8000 จะ bypass proxy + พังตอน deploy ไกล)
RUN npm run build

# Serve stage
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
